// Schéma Prisma — vit dans l'INFRASTRUCTURE. Le domaine ne le connaît pas (ADR-0002).
// Modèle relationnel dérivé de docs/architecture/05-modele-metier.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaType {
  MOVIE
  SERIES
  BOOK
}

/// Unité de progression d'un média (ADR-0017). Extensible : CHAPTERS, VOLUMES, MINUTES…
enum ProgressUnit {
  PAGES
  PERCENT
}

enum WatchStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  DROPPED
  PAUSED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  displayName  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  libraryItems   LibraryItem[]
  lists          List[]
  reviews        Review[]
  episodeReviews EpisodeReview[]
  sessions       Session[]
}

/**
 * Session opaque (jeton → utilisateur), avec expiration. Remplace le stockage Redis :
 * l'hébergement gratuit à service unique n'a pas de Redis (ADR-0012). Le domaine ne
 * connaît pas ce modèle — il passe par le port `SessionStore`.
 */
model Session {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/**
 * Œuvre regroupant plusieurs médias : série de tomes, cycle de romans. Générique par
 * construction — une saga de films suivrait le même modèle sans migration (ADR-0018).
 *
 * `method` trace **comment** le rattachement a été établi (donnée du fournisseur, ou
 * titre + auteur) : un regroupement discutable reste ainsi identifiable et corrigeable
 * après coup, sans deviner.
 */
model Collection {
  id         String   @id @default(cuid())
  provider   String
  externalId String
  title      String
  method     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  media      Media[]

  @@unique([provider, externalId])
}

model Media {
  id               String        @id @default(cuid())
  type             MediaType
  title            String
  year             Int?
  posterUrl        String?
  runtimeMinutes   Int?
  /** Date de sortie (film). Null = inconnue. Alimente l'agenda « À venir ». */
  releaseDate      DateTime?
  /** Dernière synchro de la structure saisons/épisodes (séries). Null = jamais. Garde-fou de fraîcheur du rafraîchissement « À venir ». */
  episodesSyncedAt DateTime?
  externalProvider String
  externalId       String
  genres           String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  seasons          Season[]
  libraryItems     LibraryItem[]
  listItems        ListItem[]
  reviews          Review[]
  book             BookMetadata?
  /// Œuvre dont ce média est un volume (tome de manga, tome d'un cycle). Null sinon.
  collection       Collection?   @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  collectionId     String?
  /// Rang du volume dans l'œuvre. Null pour un hors-série.
  collectionPosition Int?

  @@unique([externalProvider, externalId])
  @@index([type])
  @@index([collectionId, collectionPosition])
}

/**
 * Données propres aux livres, en table dédiée plutôt qu'en colonnes de `Media` : le média
 * générique reste mince et les types futurs (manga, BD…) suivront le même patron —
 * une table de spécialisation par type (ADR-0003).
 *
 * `sources` trace les fournisseurs ayant contribué à la fiche après fusion (ADR-0016).
 */
model BookMetadata {
  mediaId       String   @id
  media         Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  subtitle      String?
  authors       String[]
  description   String?
  pageCount     Int?
  publisher     String?
  /// Date de publication brute du fournisseur (`YYYY`, `YYYY-MM` ou `YYYY-MM-DD`).
  publishedDate String?
  /// Code langue ISO 639-1, ex. `fr`.
  language      String?
  categories    String[]
  isbn10        String?
  isbn13        String?
  googleBooksId String?
  openLibraryId String?
  infoUrl       String?
  previewUrl    String?
  /// Note moyenne du fournisseur (échelle 0–5 chez Google Books, normalisée en 0–10).
  averageRating Float?
  ratingsCount  Int?
  coverUrlLarge String?
  sources       String[]
  /// Auteurs concaténés, tenus à jour à l'écriture. Une colonne dédiée est nécessaire
  /// parce que PostgreSQL refuse d'indexer `array_to_string(authors, ' ')` : cette
  /// fonction n'est pas IMMUTABLE. C'est elle que l'index trigramme couvre, ce qui rend
  /// la recherche partielle par auteur rapide (voir migration `author_search`).
  authorsText   String?
  updatedAt     DateTime @updatedAt

  @@index([isbn13])
  @@index([googleBooksId])
  @@index([openLibraryId])
}

model Season {
  id       String    @id @default(cuid())
  media    Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId  String
  number   Int
  episodes Episode[]

  @@unique([mediaId, number])
}

model Episode {
  id             String           @id @default(cuid())
  season         Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId       String
  number         Int
  title          String
  runtimeMinutes Int?
  /** Date de diffusion (fournie par le catalogue). Null = inconnue → considérée « sortie ». */
  airDate        DateTime?
  watchedBy      WatchedEpisode[]
  reviews        EpisodeReview[]

  @@unique([seasonId, number])
}

model LibraryItem {
  id         String           @id @default(cuid())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  media      Media            @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId    String
  status     WatchStatus      @default(PLANNED)
  rating     Int?
  isFavorite Boolean          @default(false)
  addedAt    DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  /// Début/fin de consommation. Générique (tous types de média), alimenté d'abord par
  /// la lecture ; un film « vu » pourra les renseigner sans nouvelle migration.
  startedAt  DateTime?
  finishedAt DateTime?
  /// Progression courante, exprimée dans `progressUnit` (ADR-0017). Null = non suivie.
  progressUnit  ProgressUnit?
  progressValue Int?
  /// Total connu (pages du livre). Null si inconnu du catalogue et non saisi.
  progressTotal Int?
  watched    WatchedEpisode[]
  progress   ProgressEntry[]

  @@unique([userId, mediaId])
  @@index([userId, status])
}

/**
 * Historique horodaté des avancements — pendant de `WatchedEpisode` pour les médias à
 * progression continue. C'est la source des statistiques temporelles (pages par mois,
 * rythme de lecture) : sans lui, seule la valeur courante serait connue (ADR-0017).
 */
model ProgressEntry {
  id            String       @id @default(cuid())
  libraryItem   LibraryItem  @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  libraryItemId String
  unit          ProgressUnit
  fromValue     Int
  toValue       Int
  occurredAt    DateTime     @default(now())

  @@index([libraryItemId, occurredAt])
}

model WatchedEpisode {
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  libraryItemId String
  episode       Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  episodeId     String
  watchedAt     DateTime    @default(now())

  @@id([libraryItemId, episodeId])
}

model List {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  name      String
  createdAt DateTime   @default(now())
  items     ListItem[]

  @@index([userId])
}

model ListItem {
  list     List   @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId   String
  media    Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId  String
  position Int

  @@id([listId, mediaId])
}

model Review {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId   String
  body      String
  rating    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mediaId])
}

// Note et/ou avis d'un utilisateur sur un épisode précis (extension de la notation/avis
// du niveau média au niveau épisode — voir ADR-0011). `rating` et `body` sont tous deux
// optionnels (une note peut exister sans avis), mais au moins l'un des deux est renseigné.
model EpisodeReview {
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  episodeId String
  rating    Int?
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, episodeId])
}

/**
 * État d'exécution d'une tâche périodique (ADR-0019).
 *
 * Le service d'hébergement gratuit **s'endort** : une planification en processus ne se
 * déclencherait pas pendant le sommeil, et les exécutions manquées seraient perdues.
 * L'échéance est donc portée par la donnée, et la tâche est déclenchée par les lectures
 * utilisateur — le même principe que le rafraîchissement des séries suivies.
 *
 * `startedAt` sert de verrou : sa mise à jour conditionnelle et atomique garantit qu'une
 * seule requête déclenche la tâche, même si plusieurs arrivent ensemble.
 */
model SyncState {
  job        String    @id
  startedAt  DateTime?
  finishedAt DateTime?
  /// `SUCCESS`, `FAILED`, ou null tant qu'aucune exécution ne s'est achevée.
  status     String?
  lastError  String?
  updatedAt  DateTime  @updatedAt
}

// Journal des événements de domaine — source de vérité pour historique/stats/reco (ADR-0006).
model DomainEvent {
  id         String   @id @default(cuid())
  name       String
  userId     String?
  mediaId    String?
  payload    Json
  occurredAt DateTime @default(now())

  @@index([name])
  @@index([userId])
}
