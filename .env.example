# Copiez ce fichier en `.env` et ajustez les valeurs. Ne committez jamais `.env`.

# API
NODE_ENV=development
PORT=3000

# PostgreSQL (voir docker-compose.yml)
DATABASE_URL=postgresql://otium:otium@localhost:5432/otium?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Origine autorisée pour le CORS (frontend Vite)
WEB_ORIGIN=http://localhost:5173

# TMDB — jeton v4 "API Read Access Token" (https://www.themoviedb.org/settings/api)
# Laisser vide pour démarrer sans recherche ; la requête renverra alors 503.
TMDB_ACCESS_TOKEN=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w342
TMDB_CACHE_TTL_SECONDS=86400

# Frontend (Vite) — URL de base de l'API
VITE_API_URL=http://localhost:3000/api
