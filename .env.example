# Copiez ce fichier en `.env` et ajustez les valeurs. Ne committez jamais `.env`.

# API
NODE_ENV=development
PORT=3000

# PostgreSQL (voir docker-compose.yml). En production, une base gratuite Neon
# (durable, scale-to-zero) fait l'affaire — voir docs/deployment.md.
DATABASE_URL=postgresql://otium:otium@localhost:5432/otium?schema=public

# Origine autorisée pour le CORS (frontend Vite).
# En prod à service unique (l'API sert le SPA), mettre l'URL publique du service.
WEB_ORIGIN=http://localhost:5173

# Chemin du SPA buildé servi par l'API (prod, service unique). Vide = API seule (dev).
# WEB_DIST_PATH=../web/dist

# TMDB — jeton v4 "API Read Access Token" (https://www.themoviedb.org/settings/api)
# Laisser vide pour démarrer sans recherche ; la requête renverra alors 503.
TMDB_ACCESS_TOKEN=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w342
TMDB_CACHE_TTL_SECONDS=86400

# Livres — Google Books (source principale) puis Open Library (secours). Voir ADR-0016.
# La clé Google est FACULTATIVE : sans elle, l'API répond avec un quota anonyme plus bas.
# https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=
GOOGLE_BOOKS_API_BASE_URL=https://www.googleapis.com/books/v1
OPEN_LIBRARY_API_BASE_URL=https://openlibrary.org
# 7 jours : les métadonnées d'un livre ne bougent pas (éco-conception).
BOOKS_CACHE_TTL_SECONDS=604800

#TWITCH
client_id=Client ID
client_secret=Client Secret
grant_type=client_credentials

# Frontend (Vite) — URL de base de l'API
VITE_API_URL=http://localhost:3000/api
